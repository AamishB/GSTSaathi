# ===========================================
# LLM Configuration
# ===========================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Get your API key from: https://makersuite.google.com/app/apikey
MODEL_NAME=gemini-2.0-flash
MAX_TOKENS=2048
TEMPERATURE=0.7

# ===========================================
# Database
# ===========================================
DATABASE_URL=sqlite:///./gst_compliance.db
CHROMA_PERSIST_DIR=./gst_law_db

# ===========================================
# Authentication
# ===========================================
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# File Upload
# ===========================================
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=50

# ===========================================
# Server
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ===========================================
# Frontend URL (for CORS)
# ===========================================
FRONTEND_URL=http://localhost:5173
